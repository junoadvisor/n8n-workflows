          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"response_text\": $json.body.response_text, \"response_type\": \"public_comment\" } }}",
        "options": {}
      },
      "id": "forward-to-yelp-api",
